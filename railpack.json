{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "caches": {
    "aesthetics-gallery-images": {
      "directory": "/root/.cache/aesthetics-gallery-images",
      "type": "shared"
    }
  },
  "steps": {
    "build": {
      "commands": [
        "AESTHETICS_IMAGE_CACHE_DIR=/root/.cache/aesthetics-gallery-images npm run build"
      ],
      "caches": ["...", "aesthetics-gallery-images"]
    }
  },
  "deploy": {
    "startCommand": "npm run start"
  }
}
